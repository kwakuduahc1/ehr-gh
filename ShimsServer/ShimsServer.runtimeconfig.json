{
  "runtimeOptions": {
    "tfm": "net10.0",
    "framework": {
      "name": "Microsoft.AspNetCore.App",
      "version": "10.0.0"
    },
    "configProperties": {
      "System.GC.Server": true,
      "System.GC.RetainVM": false,
      "System.GC.HeapCount": 2,
      "System.GC.HeapAffinitizeMask": "0x00000003",
      "System.GC.Concurrent": true,
      "System.GC.HeapHardLimit": 536870912,
      "System.GC.HeapHardLimitPercent": 75,
      "System.GC.LOHThreshold": 85000
    }
  }
}
